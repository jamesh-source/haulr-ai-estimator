# =============================================================================
# HAULR AI ESTIMATOR — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in all values before running the app.
# Never commit .env.local to source control.
# =============================================================================

# -----------------------------------------------------------------------------
# CLERK — Authentication & User Management
# https://dashboard.clerk.com
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# -----------------------------------------------------------------------------
# SUPABASE — Database & Storage
# https://app.supabase.com → Project → Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres direct connection string (for migrations / server-side only)
DATABASE_URL=

# -----------------------------------------------------------------------------
# OPENAI — AI Photo Analysis & Estimating
# https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# GOOGLE MAPS — Address Autocomplete & Distance Calculation
# https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Maps JavaScript API, Distance Matrix API, Geocoding API, Places API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# STRIPE — Payments & Subscriptions
# https://dashboard.stripe.com/apikeys
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe webhook secret — from: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# APP CONFIG
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_COMPANY_NAME=HAULR
